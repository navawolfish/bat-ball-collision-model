     ]
    }
   ],
   "source": [
    "#eigenvals nava\n",
    "evalsA, evecsA = np.linalg.eig(H_nava)\n",
    "omegaA = np.sqrt(np.abs(evalsA))\n",
    "freqsA = omegaA / (2 * np.pi)\n",
    "freqsA.sort()\n",
    "print(freqsA[:10])"
   ]
