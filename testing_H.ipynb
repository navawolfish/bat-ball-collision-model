   "source": [
    "## **Standard Bat**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "9d8780d2",
   "metadata": {},
   "outputs": [],
   "source": [
    "H_alan = load_H_matrix('data/H_matrix_Alan.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "2ec7865b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# edge case ij, ji, all of jj\n",
    "# \n",
    "mass = 0.885 # in kg\n",
    "rho = 649 # in kg/m^3\n",
    "\n",
    "Y = 1.814 * 1e10  # convert to N/m^2\n",
    "S = 1.05 * 1e9 # convert to N/m^2\n",
    "N = 84  # number of slices\n",
    "dz = 0.84 / N # slice thickness in m\n",
    "\n",
    "# load bat profile\n",
    "bat_prof = np.loadtxt('data/r161.dat')\n",
    "bat_prof[:, 1] = bat_prof[:, 1] / 2 # convert diameter to radius\n",
    "Ai = np.pi * (bat_prof[:, 1] * 1e-3)**2  # in m^2\n",
    "Vi = Ai * dz  # in m^3\n",
    "Ii = np.pi/4 * (bat_prof[:, 1] * 1e-3)**4  # in m^4\n",
    "\n",
    "Lam = S / (rho * dz**2)\n",
    "Ups = Y / (rho * dz**2)\n",
    "H_nava = create_system_matrices(N, Ai, Ii, dz, S, Y, rho)"
   ]
  },
